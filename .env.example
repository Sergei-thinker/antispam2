# =============================================================================
# Telegram Anti-Spam Bot v2 - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Telegram Bot ---
# Bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token

# --- OpenRouter AI ---
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# --- Access Control ---
# JSON array of Telegram user IDs who can manage the bot
ADMIN_IDS=[123456789]

# --- Channel ---
# Target channel ID (starts with -100 for supergroups/channels)
CHANNEL_ID=-1001234567890

# --- AI Model Settings ---
# OpenRouter model identifier for spam classification
AI_MODEL=anthropic/claude-sonnet-4.6

# Confidence threshold (0.0-1.0) above which a message is classified as spam
SPAM_CONFIDENCE_THRESHOLD=0.7

# --- Message Limits ---
# Maximum message length to process (longer messages are truncated)
MAX_MESSAGE_LENGTH=4000

# Maximum number of few-shot examples to include in AI prompt
MAX_FEW_SHOT_EXAMPLES=10

# --- OpenRouter Connection ---
# Request timeout in seconds
OPENROUTER_TIMEOUT=30

# Number of retries on failed API calls
OPENROUTER_MAX_RETRIES=3

# --- Rate Limiting ---
# Maximum number of AI classification calls per minute
MAX_AI_CALLS_PER_MINUTE=20

# --- Database ---
# Path to SQLite database file (relative to project root)
DATABASE_PATH=data/antispam.db

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (structured) or console (human-readable)
LOG_FORMAT=json
